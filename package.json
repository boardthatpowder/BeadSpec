{
  "name": "beadspec",
  "version": "0.1.1",
  "description": "A native desktop GUI for the Beads issue tracker — visualize dependencies, track velocity, and browse OpenSpec changes without leaving your workflow.",
  "author": "Dean Hart",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/boardthatpowder/BeadSpec.git"
  },
  "homepage": "https://boardthatpowder.github.io/BeadSpec",
  "bugs": {
    "url": "https://github.com/boardthatpowder/BeadSpec/issues"
  },
  "keywords": [
    "tauri",
    "desktop",
    "issue-tracker",
    "beads",
    "openspec",
    "dolt",
    "rust",
    "react"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run gen-bindings && tsc && vite build",
    "build:no-bindings": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "gen-bindings": "cd src-tauri && cargo test --test bindings",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tiptap/extension-code-block-lowlight": "^3.23.1",
    "@tiptap/extension-task-item": "^3.23.1",
    "@tiptap/extension-task-list": "^3.23.1",
    "@tiptap/pm": "^3.23.1",
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.2",
    "lowlight": "^3.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hotkeys-hook": "^5.3.2",
    "react-resizable-panels": "^4.11.0",
    "recharts": "^3.8.1",
    "tiptap-markdown": "^0.9.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@types/cytoscape": "^3.31.0",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^28.0.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
