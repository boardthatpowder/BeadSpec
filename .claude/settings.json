{
  "enabledPlugins": {
    "ruflo-agentdb@ruflo": true,
    "ruflo-autopilot@ruflo": true,
    "ruflo-core@ruflo": true,
    "ruflo-cost-tracker@ruflo": true,
    "ruflo-intelligence@ruflo": true,
    "ruflo-loop-workers@ruflo": true,
    "ruflo-rag-memory@ruflo": true,
    "ruflo-security-audit@ruflo": true,
    "ruflo-swarm@ruflo": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ruflo-post-push.sh",
            "type": "command"
          },
          {
            "async": true,
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/gitnexus-analyze.sh",
            "statusMessage": "Updating GitNexus index...",
            "timeout": 300,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ruflo-post-edit.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ruflo-pre-edit.sh",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ruflo-pre-commit.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "openspec list 2\u003e/dev/null | head -20",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "source ~/.claude/ruflo/lib/tags.sh 2\u003e/dev/null \u0026\u0026 ruflo memory search -q \"recent context $(git branch --show-current 2\u003e/dev/null)\" 2\u003e/dev/null | head -20 || true",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "ruflo hooks session-restore 2\u003e/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ruflo-session-end.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "skillListingBudgetFraction": 0.2
}