
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/pid
.beads/port
.beads/*.log
.beads/*.lock
.beads/dolt/

# Rust build artifacts
target/
src-tauri/target/

# Frontend
dist/
node_modules/

# Tauri generated
src-tauri/gen/

# Environment
.env
.env.local
.env.*.local

# macOS
.DS_Store

# Local vector store
ruvector.db

# Dolt server supervisor PID (runtime file, never committed)
.beads/embeddeddolt/.supervisor.pid

# Agent tooling (machine-local state, hardcoded paths, runtime sessions)
.agents/
.claude-flow/

# SQLite sidecars (*.db covers the main file, but not these)
*.db-shm
*.db-wal
*.db-journal

# AgentDB / RuVector runtime (data file + lockfile)
agentdb.rvf*

# Skills cache
skills-lock.json

# Claude local settings and plans
.claude/settings.local.json
.claude/plans/

# Build outputs
build/
coverage/
.cache/
.tmp/
tmp/

# GitNexus index (local, regenerated)
.gitnexus/

# Beads runtime (extended)
.beads/dolt-server.*
.beads/.local_version
.beads/interactions.jsonl
.beads/backup/
.beads/export-state/
.beads/export-state.json
.beads/push-state.json
.beads/.env
.beads/embeddeddolt/

# Vim swap files
*.swp
*.swo

# Allow .env.example, ignore all other .env variants
.env.*
!.env.example

# VitePress docs site build outputs
docs-site/.vitepress/dist
docs-site/.vitepress/cache
